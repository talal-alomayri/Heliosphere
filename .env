# ─────────────────────────────────────────────────────────────────────────────
# Heliosphere — Environment Variables
#
# All variables MUST be prefixed with VITE_ so Vite exposes them to the client
# via import.meta.env. Variables without this prefix are invisible to the app.
#
# ⚠  Never commit real secrets to git.  Add .env to .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the Solar System OpenData REST API.
# Used as the proxy target in vite.config.js — never accessed directly by the
# browser (avoids CORS preflight issues when Authorization header is present).
VITE_SPACE_API_URL=https://api.le-systeme-solaire.net/rest

# Bearer token for authenticated API requests.
# Obtain a free key at: https://api.le-systeme-solaire.net/generatekey.html
VITE_SPACE_API_TOKEN=5b093cea-3cc3-4174-bd65-5f964441e21e
